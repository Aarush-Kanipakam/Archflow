// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  boards       Board[]        // Boards this user owns
  memberships  BoardMember[]  // Boards shared with this user
  sessions     Session[]      // Active login sessions
}

model Board {
  id        String   @id @default(uuid())
  title     String   @default("Untitled Board")
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  owner     User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  shapes    Shape[]
  members   BoardMember[]
}

model Shape {
  id        String   @id @default(uuid())
  boardId   String
  type      ShapeType
  x         Float
  y         Float
  width     Float    @default(100)
  height    Float    @default(100)
  rotation  Float    @default(0)
  fill      String   @default("#4A90D9")
  stroke    String   @default("#2C5F8A")
  strokeWidth Float  @default(2)
  text      String?
  fontSize  Int      @default(16)
  
  // Arrow/Line specific points: [x1, y1, x2, y2, ...]
  points    Float[]
  
  zIndex    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
}

model BoardMember {
  id      String        @id @default(uuid())
  boardId String
  userId  String
  role    BoardRole     @default(EDITOR)
  
  board   Board         @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([boardId, userId])  // a user can only be a member once per board
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ShapeType {
  RECTANGLE
  CIRCLE
  TEXT
  ARROW
  LINE
}

enum BoardRole {
  VIEWER
  EDITOR
}
